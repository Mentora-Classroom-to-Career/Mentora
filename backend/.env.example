# Copy to .env and adjust for your machine.

# Defaults to a local SQLite file if unset — fine for Phase 1/2 dev.
# For the real target stack, point this at Postgres:
#   DATABASE_URL=postgresql://postgres:<password>@localhost:5432/mentora_db
DATABASE_URL=sqlite:///./mentora.db

# Generate a real secret before this ever leaves your machine, e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-real-secret
JWT_EXPIRE_MINUTES=10080

FRONTEND_ORIGIN=http://localhost:3000
DEBUG=true

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi4-mini
